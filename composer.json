{
    "name": "phalcon/migrations",
    "description": "Run and Generate DB Migrations with Phalcon Framework",
    "version": "4.0.0",
    "keywords": [
        "framework",
        "phalcon",
        "migration",
        "phar"
    ],
    "homepage": "https://phalcon.io",
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "Phalcon Team",
            "email": "team@phalcon.io",
            "homepage": "https://phalcon.io/en/team"
        },
        {
            "name": "Contributors",
            "homepage": "https://github.com/phalcon/migrations/graphs/contributors"
        }
    ],
    "support": {
        "issues": "https://github.com/phalcon/migrations/issues",
        "source": "https://github.com/phalcon/migrations",
        "forum": "https://forum.phalcon.io"
    },
    "require": {
        "php": ">=8.2",
        "phalcon/cli-options-parser": "^2.0",
        "nette/php-generator": "^4.0"
    },
    "require-dev": {
        "ext-pdo": "*",
        "friendsofphp/php-cs-fixer": "^3.95",
        "pds/skeleton": "^1.0",
        "pds/composer-script-names": "^1.0",
        "phpunit/phpunit": "^11.5",
        "squizlabs/php_codesniffer": "^4.0",
        "fakerphp/faker": "^1.24",
        "humbug/box": "^4.7",
        "vlucas/phpdotenv": "^5.6",
        "phpstan/phpstan": "^2.1",
        "vimeo/psalm": "^6.16"
    },
    "autoload": {
        "psr-4": {
            "Phalcon\\Migrations\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalcon\\Db\\": "tests/Fakes/Shims/Phalcon/Db/",
            "Phalcon\\Migrations\\Tests\\": "tests/",
            "Phalcon\\Migrations\\Tests\\Fakes\\": "tests/Fakes/",
            "Phalcon\\Migrations\\Tests\\Unit\\": "tests/unit/"
        }
    },
    "suggest": {
        "robmorgan/phinx": "Phinx makes it ridiculously easy to manage the database migrations for your PHP app."
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "archive": {
        "exclude": [
            "/.github",
            "/tests",
            ".codacy.yml",
            ".codecov.yml",
            "CHANGELOG.md",
            "resources/phpcs.xml",
            "resources/phpstan.neon.dist",
            "resources/psalm.xml.dist"
        ]
    },
    "bin": [
        "bin/phalcon-migrations"
    ],
  "scripts": {
    "analyze": "vendor/bin/phpstan analyse -c resources/phpstan.neon.dist",
    "analyze-psalm": "vendor/bin/psalm -c resources/psalm.xml.dist",
    "cs": "vendor/bin/phpcs --standard=resources/phpcs.xml",
    "cs-fix": "vendor/bin/phpcbf --standard=resources/phpcs.xml",
    "cs-fixer": "vendor/bin/php-cs-fixer fix --config=resources/php-cs-fixer.php --dry-run --diff",
    "cs-fixer-fix": "vendor/bin/php-cs-fixer fix --config=resources/php-cs-fixer.php",
    "test": "vendor/bin/phpunit -c resources/phpunit.xml.dist",
    "test-coverage": "vendor/bin/phpunit -c resources/phpunit.xml.dist --coverage-clover tests/_output/coverage/clover.xml",
    "test-coverage-html": "vendor/bin/phpunit -c resources/phpunit.xml.dist --coverage-html tests/_output/coverage/html/"
  }
}
