<?xml version="1.0"?>
<psalm
    errorLevel="3"
    resolveFromConfigFile="true"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
>
    <projectFiles>
        <directory name="src" />
        <ignoreFiles>
            <directory name="vendor" />
        </ignoreFiles>
    </projectFiles>
    <issueHandlers>
        <!--
            Existing suppressions carried over from the original config.
        -->
        <MethodSignatureMismatch errorLevel="info" />
        <InvalidArgument errorLevel="info" />
        <PossiblyUndefinedArrayOffset errorLevel="info" />

        <!--
            PHP 8.3 introduced #[\Override]. The project targets PHP 8.2,
            so this attribute cannot be used.
        -->
        <MissingOverrideAttribute errorLevel="suppress" />

        <!--
            Public library API — classes and methods are entry-points consumed
            by user code and by the CLI binary; Psalm cannot see those callers.
        -->
        <UnusedClass errorLevel="suppress" />
        <PossiblyUnusedMethod errorLevel="suppress" />
        <PossiblyUnusedParam errorLevel="suppress" />

        <!--
            isset($array[$nullable]) is safe in PHP: it returns false when the
            key is null, it does not throw. The code wraps every access in an
            isset() guard so no runtime error is possible.
        -->
        <PossiblyNullArrayOffset errorLevel="suppress" />

        <!--
            Psalm contradicts itself on pow(): it calls the (int) cast both
            redundant and required in the same expression. Suppress the
            redundant-cast notice so the cast can stay for the binary-operand
            check to pass.
        -->
        <RedundantCast errorLevel="suppress" />

        <!--
            Migrations::$storage is typed as string|AdapterInterface|null and
            the file-path branches are only reached when the value is a string.
            Psalm cannot track the conditional assignment, so the cast warnings
            are false positives.
        -->
        <PossiblyInvalidCast errorLevel="suppress" />
    </issueHandlers>
</psalm>
